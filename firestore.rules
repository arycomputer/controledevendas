
/**
 * This ruleset enforces a simple, yet secure, access model for the VendasControl application.
 * Updated to include explicit permissions for the 'purchases' collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
       return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }


    // --------------------------------
    // Collection Rules
    // --------------------------------

    match /customers/{customerId} {
      allow read, write: if isSignedIn();
    }

    match /parts/{partId} {
      allow read, write: if isSignedIn();
    }

    match /sales/{saleId} {
      allow read, write: if isSignedIn();
    }

    match /purchases/{purchaseId} {
      allow read, write: if isSignedIn();
    }

    match /serviceOrders/{serviceOrderId} {
      allow read, write: if isSignedIn();
    }
    
    match /budgets/{budgetId} {
        allow read, write: if isSignedIn();
    }

    match /discards/{discardId} {
      allow read, write: if isSignedIn();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
        allow read, write: if isSignedIn();
    }
  }
}
