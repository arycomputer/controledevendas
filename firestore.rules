
/**
 * Ruleset for VendasControl - Versão 1.8.0
 * Ajuste global para permissões recursivas e acesso total a coleções de negócio.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funções auxiliares
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
       return isSignedIn() && 
       exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Permissões para Coleções de Negócio
    // O padrão {allPaths=**} garante que a permissão se estenda a todos os documentos e subcoleções
    match /customers/{allPaths=**} { allow read, write: if isSignedIn(); }
    match /parts/{allPaths=**} { allow read, write: if isSignedIn(); }
    match /sales/{allPaths=**} { allow read, write: if isSignedIn(); }
    match /purchases/{allPaths=**} { allow read, write: if isSignedIn(); }
    match /serviceOrders/{allPaths=**} { allow read, write: if isSignedIn(); }
    match /budgets/{allPaths=**} { allow read, write: if isSignedIn(); }
    match /discards/{allPaths=**} { allow read, write: if isSignedIn(); }
    match /settings/{allPaths=**} { allow read, write: if isSignedIn(); }

    // Perfis de Usuário
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
  }
}
