
/**
 * Ruleset for VendasControl - Versão 1.0.9
 * Aplicando wildcards recursivos para garantir permissões de listagem em todas as coleções.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funções auxiliares
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
       return isSignedIn() && 
       exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Regra Geral para usuários autenticados em coleções de negócio
    // O uso de {document=**} garante que listagens e subcoleções funcionem corretamente
    
    match /customers/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /parts/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /sales/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /purchases/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /serviceOrders/{document=**} {
      allow read, write: if isSignedIn();
    }
    
    match /budgets/{document=**} {
        allow read, write: if isSignedIn();
    }

    match /discards/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /settings/{document=**} {
        allow read, write: if isSignedIn();
    }

    // Perfis de Usuário - Regra específica para proteção de roles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
  }
}
