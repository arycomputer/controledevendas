
/**
 * Ruleset for VendasControl - Versão 1.5.0
 * Ajuste de permissões globais para evitar erros de listagem em novas coleções.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funções auxiliares
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
       return isSignedIn() && 
       exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Permissões para Coleções de Negócio
    // O padrão {document=**} garante que tanto a coleção raiz quanto sub-documentos
    // sejam cobertos pelas permissões de leitura e escrita.
    match /customers/{document=**} { allow read, write: if isSignedIn(); }
    match /parts/{document=**} { allow read, write: if isSignedIn(); }
    match /sales/{document=**} { allow read, write: if isSignedIn(); }
    match /purchases/{document=**} { allow read, write: if isSignedIn(); }
    match /serviceOrders/{document=**} { allow read, write: if isSignedIn(); }
    match /budgets/{document=**} { allow read, write: if isSignedIn(); }
    match /discards/{document=**} { allow read, write: if isSignedIn(); }
    match /settings/{document=**} { allow read, write: if isSignedIn(); }

    // Perfis de Usuário
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
  }
}
