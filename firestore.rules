
/**
 * Ruleset for VendasControl - Versão 1.0.8
 * Forçando atualização de permissões para a coleção de Compras.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
       return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Clientes
    match /customers/{customerId} {
      allow read, write: if isSignedIn();
    }

    // Produtos e Serviços
    match /parts/{partId} {
      allow read, write: if isSignedIn();
    }

    // Vendas
    match /sales/{saleId} {
      allow read, write: if isSignedIn();
    }

    // Compras e Entrada de Estoque
    // Explicitamente permitindo read (get + list) e write (create + update + delete)
    match /purchases/{purchaseId} {
      allow read, write: if isSignedIn();
    }

    // Ordens de Serviço
    match /serviceOrders/{serviceOrderId} {
      allow read, write: if isSignedIn();
    }
    
    // Orçamentos
    match /budgets/{budgetId} {
        allow read, write: if isSignedIn();
    }

    // Descartes
    match /discards/{discardId} {
      allow read, write: if isSignedIn();
    }

    // Perfis de Usuário
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Configurações Globais
    match /settings/{settingId} {
        allow read, write: if isSignedIn();
    }
  }
}
