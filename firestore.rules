
/**
 * Ruleset for VendasControl - Versão 1.2.0
 * Correção definitiva para permissões de listagem e criação automática de coleções.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funções auxiliares
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
       return isSignedIn() && 
       exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Regra Global para Coleções de Negócio
    // Permite leitura e escrita para qualquer usuário autenticado em coleções padrão
    match /customers/{document=**} { allow read, write: if isSignedIn(); }
    match /parts/{document=**} { allow read, write: if isSignedIn(); }
    match /sales/{document=**} { allow read, write: if isSignedIn(); }
    match /purchases/{document=**} { allow read, write: if isSignedIn(); }
    match /serviceOrders/{document=**} { allow read, write: if isSignedIn(); }
    match /budgets/{document=**} { allow read, write: if isSignedIn(); }
    match /discards/{document=**} { allow read, write: if isSignedIn(); }
    match /settings/{document=**} { allow read, write: if isSignedIn(); }

    // Perfis de Usuário
    // Usuários podem ler qualquer perfil, mas só editar o próprio ou se for admin
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
  }
}
