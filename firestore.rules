
/**
 * Ruleset for VendasControl - Versão 1.1.2
 * Ajuste de permissões para garantir acesso a coleções novas e provisionamento.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funções auxiliares
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
       return isSignedIn() && 
       exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Permissões para Coleções de Negócio
    // O padrão {doc=**} permite operações na coleção (list) e em todos os documentos (get, write)
    
    match /customers/{doc=**} {
      allow read, write: if isSignedIn();
    }

    match /parts/{doc=**} {
      allow read, write: if isSignedIn();
    }

    match /sales/{doc=**} {
      allow read, write: if isSignedIn();
    }

    match /purchases/{doc=**} {
      allow read, write: if isSignedIn();
    }

    match /serviceOrders/{doc=**} {
      allow read, write: if isSignedIn();
    }
    
    match /budgets/{doc=**} {
        allow read, write: if isSignedIn();
    }

    match /discards/{doc=**} {
      allow read, write: if isSignedIn();
    }

    match /settings/{doc=**} {
        allow read, write: if isSignedIn();
    }

    // Perfis de Usuário
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
  }
}
