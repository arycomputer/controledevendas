
{
  "entities": {
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "type": "object",
      "description": "Represents a customer with their contact information and address.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "document": { "type": "string" },
        "phone": { "type": "string" },
        "zipCode": { "type": "string" },
        "street": { "type": "string" },
        "number": { "type": "string" },
        "complement": { "type": "string" },
        "neighborhood": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product or service in the inventory.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "quantity": { "type": "number" },
        "type": { "type": "string", "enum": ["piece", "service"] },
        "link": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "name", "price", "type"]
    },
    "Sale": {
      "title": "Sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "saleDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["paid", "pending", "cancelled"] }
      }
    },
    "FinancialTransaction": {
      "title": "FinancialTransaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "description", "amount", "type", "date"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "customers/{customerId}", "definition": { "entityName": "Customer" } },
      { "path": "parts/{partId}", "definition": { "entityName": "Product" } },
      { "path": "sales/{saleId}", "definition": { "entityName": "Sale" } },
      { "path": "purchases/{purchaseId}", "definition": { "entityName": "Purchase" } },
      { "path": "transactions/{transactionId}", "definition": { "entityName": "FinancialTransaction" } },
      { "path": "serviceOrders/{serviceOrderId}", "definition": { "entityName": "ServiceOrder" } },
      { "path": "budgets/{budgetId}", "definition": { "entityName": "Budget" } },
      { "path": "discards/{discardId}", "definition": { "entityName": "Discard" } },
      { "path": "users/{userId}", "definition": { "entityName": "User" } },
      { "path": "settings/{settingId}", "definition": { "entityName": "Settings" } }
    ]
  }
}
